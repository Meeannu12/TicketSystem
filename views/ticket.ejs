<!DOCTYPE html>
<html>

<head>
    <meta charset="UTF-8">
    <title>Ticket</title>

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background: #f5f5f5;
            margin: 0;
            padding: 20px;
            font-family: Arial, sans-serif;
        }

        .ticket-card {
            width: 100%;
            max-width: 850px;
            margin: 20px auto;
            background: white;
            border-radius: 20px;
            overflow: hidden;
            box-shadow: 0 5px 20px rgba(0, 0, 0, .1);
        }

        .header {
            background: #24126A;
            color: white;
            text-align: center;
            padding: 30px;
        }

        .header h1 {
            font-size: 42px;
        }

        .description {
            text-align: center;
            padding: 30px;
            font-size: 22px;
            font-weight: 600;
        }

        .content {
            display: flex;
            gap: 30px;
            padding: 30px;
        }

        .left {
            flex: 2;
        }

        .right {
            flex: 1;
        }

        .info-row {
            padding: 20px 0;
            border-bottom: 1px solid #ddd;
        }

        .info-row strong {
            font-size: 20px;
        }

        .qr-box {
            background: white;
            border-radius: 15px;
            padding: 20px;
            box-shadow: 0 0 15px rgba(0, 0, 0, .15);
            text-align: center;
        }

        .qr-box img {
            width: 220px;
            max-width: 100%;
            height: auto;
        }

        .scan-title {
            background: #24126A;
            color: white;
            padding: 10px;
            border-radius: 10px;
            margin-bottom: 15px;
        }

        .venue {
            padding: 20px 30px;
        }

        .note {
            background: #24126A;
            color: white;
            text-align: center;
            margin: 20px;
            padding: 12px;
            border-radius: 20px;
        }

        .logo {
            text-align: center;
            padding: 30px;
        }

        .logo img {
            width: 180px;
        }

        @media(max-width:768px) {

            .content {
                flex-direction: column;
            }

            .right {
                text-align: center;
            }

            .qr-box img {
                width: 180px;
            }

            .header h1 {
                font-size: 28px;
            }

        }
    </style>
</head>

<body>

    <div class="ticket-card">

        <div class="header">
            <!-- <h1>JAIPUR NEET EXPO 2026</h1> -->
            <h1>
                <%= userTicket.eventId.eventName %>
            </h1>
        </div>

        <div class="description">

            <%= userTicket.eventId.eventShortName %>
        </div>

        <div class="content">

            <div class="left">

                <div class="info-row">
                    <strong>Attendee :</strong>
                    <%= userTicket.name %>
                </div>

                <div class="info-row">
                    <strong>Members :</strong>
                    <%# userTicket.members.join(", ") %>
                    <%= userTicket.member?.join(" , ") || "" %>
                </div>

            <div class=" info-row">
                        <strong>Event Date :</strong>
                        <%= eventDate %>
                </div>

                <div class="info-row">
                    <strong>Event Time :</strong>
                    <%# userTicket.eventTime %>
                        <%= userTicket.eventId.startTime %> to <%= userTicket.eventId.endTime %>
                </div>

            </div>

            <div class="right">

                <div class="qr-box">

                    <div class="scan-title">
                        Scan me
                    </div>

                    <img src="<%= qrDataURL %>" />

                    <p>
                        <%= userTicket._id %>
                    </p>

                </div>

            </div>

        </div>

        <div class="venue">

            <h3>Venue:</h3>

            <a href="<%= userTicket.eventId.locationURL %>" target="_blank">
                <%= userTicket.eventId.venue %>
            </a>

        </div>

        <div class="note">
            Note : This ticket is valid for 4 members till event end.
        </div>

        <div class="logo">
            <img src="/images/Logo.png" alt="Logo">
        </div>

    </div>

</body>

</html>